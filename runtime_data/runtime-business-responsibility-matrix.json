  "escalationChain": [
    { "level": 1, "roles": ["runtimeOwner", "businessOwner"], "responseTime": "4h" },
    { "level": 2, "roles": ["emergencyController", "serviceOwner", "costOwner"], "responseTime": "1h" },
    { "level": 3, "roles": ["reviewer", "deployApprover", "repairApprover"], "responseTime": "30min" },
    { "level": 4, "roles": ["operator"], "responseTime": "15min" }
  ],
  "raciMatrix": {
    "deploy": { "responsible": "operator", "accountable": "deployApprover", "consulted": "reviewer", "informed": "serviceOwner" },
    "repair": { "responsible": "operator", "accountable": "repairApprover", "consulted": "reviewer", "informed": "serviceOwner" },
    "emergency": { "responsible": "emergencyController", "accountable": "runtimeOwner", "consulted": "serviceOwner", "informed": "businessOwner" },
    "costOptimization": { "responsible": "costOwner", "accountable": "businessOwner", "consulted": "operator", "informed": "runtimeOwner" },
    "slaManagement": { "responsible": "serviceOwner", "accountable": "runtimeOwner", "consulted": "operator", "informed": "businessOwner" },
    "governanceChange": { "responsible": "reviewer", "accountable": "runtimeOwner", "consulted": "operator", "informed": "serviceOwner" }
  },
  "lastUpdated": null

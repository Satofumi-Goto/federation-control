      "escalationLevel": 1
    },
    "operator": {
      "label": "Runtime Operator",
      "responsibilities": ["daily-execution", "monitoring", "incident-response", "queue-management"],
      "escalationLevel": 4
    },
    "reviewer": {
      "label": "Runtime Reviewer",
      "responsibilities": ["change-review", "deploy-validation", "governance-compliance-check"],
      "escalationLevel": 3
    },
    "deployApprover": {
      "label": "Deploy Approver",
      "responsibilities": ["deploy-gate-approval", "rollback-decision", "release-sign-off"],
      "escalationLevel": 3
    },
    "repairApprover": {
      "label": "Repair Approver",
      "responsibilities": ["repair-authorization", "repair-scope-validation", "repair-impact-assessment"],
      "escalationLevel": 3
    },
    "emergencyController": {
      "label": "Emergency Controller",
      "responsibilities": ["emergency-stop", "force-recovery", "incident-command", "bypass-authorization"],
      "escalationLevel": 2
    },
    "businessOwner": {
      "label": "Business Owner",
      "responsibilities": ["cost-management", "revenue-tracking", "business-impact-assessment", "budget-planning"],
      "escalationLevel": 1
    },
    "serviceOwner": {
      "label": "Service Owner",
      "responsibilities": ["sla-management", "slo-monitoring", "service-availability", "customer-impact-assessment"],

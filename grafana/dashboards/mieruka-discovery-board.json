      "gridPos": {"h": 10, "w": 7, "x": 0, "y": 4},
      "options": {
        "mode": "html",
        "content": "<div style=\"height:100%;box-sizing:border-box;padding:16px;background:#0f172a;border:1px solid rgba(148,163,184,.25);border-radius:18px;color:#fff;\"><div style=\"font-size:20px;font-weight:900;\">資料アップロード</div><div style=\"margin-top:12px;height:115px;border:2px dashed rgba(56,189,248,.55);border-radius:16px;display:flex;align-items:center;justify-content:center;text-align:center;color:#cbd5e1;line-height:1.7;\">ここにドラッグ＆ドロップ<br/>または ファイル参照<br/><span style=\"font-size:12px;color:#94a3b8;\">最大20ファイル</span></div><div style=\"margin-top:14px;display:grid;gap:10px;font-size:12px;\"><div style=\"padding:10px;background:#111827;border-radius:12px;\"><b>📊 queue_local_ops.xlsx</b><br/><span style=\"color:#94a3b8;\">2026-05-21 / 1.8MB / Queue候補</span></div><div style=\"padding:10px;background:#111827;border-radius:12px;\"><b>📄 node_acceptance.pdf</b><br/><span style=\"color:#94a3b8;\">2026-05-20 / 3.2MB / Node候補</span></div><div style=\"padding:10px;background:#111827;border-radius:12px;\"><b>🖼️ eta_screen.png</b><br/><span style=\"color:#94a3b8;\">2026-05-19 / 820KB / ETA候補</span></div><div style=\"padding:10px;background:#111827;border-radius:12px;\"><b>📑 dispatch_flow.pptx</b><br/><span style=\"color:#94a3b8;\">2026-05-18 / 5.4MB / Dispatch候補</span></div></div></div>"
      }
    },
    {

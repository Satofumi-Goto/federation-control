      "title": "Runtime推定",
      "gridPos": {"h": 10, "w": 8, "x": 7, "y": 4},
      "options": {
        "mode": "html",
        "content": "<div style=\"height:100%;box-sizing:border-box;padding:16px;background:#0f172a;border:1px solid rgba(148,163,184,.25);border-radius:18px;color:#fff;\"><div style=\"font-size:20px;font-weight:900;\">Runtime Discovery Graph</div><svg viewBox=\"0 0 520 300\" width=\"100%\" height=\"255\"><line x1=\"90\" y1=\"70\" x2=\"240\" y2=\"70\" stroke=\"#38bdf8\" opacity=\".45\"/><line x1=\"240\" y1=\"70\" x2=\"390\" y2=\"70\" stroke=\"#38bdf8\" opacity=\".45\"/><line x1=\"240\" y1=\"70\" x2=\"240\" y2=\"190\" stroke=\"#f59e0b\" opacity=\".45\"/><line x1=\"240\" y1=\"190\" x2=\"390\" y2=\"190\" stroke=\"#22c55e\" opacity=\".45\"/><circle cx=\"90\" cy=\"70\" r=\"42\" fill=\"#0ea5e9\"/><text x=\"90\" y=\"75\" text-anchor=\"middle\" fill=\"white\" font-size=\"15\" font-weight=\"800\">予約</text><circle cx=\"240\" cy=\"70\" r=\"42\" fill=\"#f59e0b\"/><text x=\"240\" y=\"75\" text-anchor=\"middle\" fill=\"white\" font-size=\"15\" font-weight=\"800\">ETA</text><circle cx=\"390\" cy=\"70\" r=\"42\" fill=\"#22c55e\"/><text x=\"390\" y=\"75\" text-anchor=\"middle\" fill=\"white\" font-size=\"15\" font-weight=\"800\">配車</text><circle cx=\"240\" cy=\"190\" r=\"42\" fill=\"#8b5cf6\"/><text x=\"240\" y=\"195\" text-anchor=\"middle\" fill=\"white\" font-size=\"15\" font-weight=\"800\">拠点</text><circle cx=\"390\" cy=\"190\" r=\"42\" fill=\"#14b8a6\"/><text x=\"390\" y=\"195\" text-anchor=\"middle\" fill=\"white\" font-size=\"15\" font-weight=\"800\">エネルギー</text><text x=\"20\" y=\"285\" fill=\"#94a3b8\" font-size=\"13\">推定：資料が増えるほど node / edge / confidence が拡張される</text></svg></div>"

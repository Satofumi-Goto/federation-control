        "content": "<a href=\"/d/go-integrated-surface/integrated-control-surface\" style=\"display:block;width:100%;height:100%;min-height:0;overflow:hidden;box-sizing:border-box;padding:12px;text-decoration:none;background:linear-gradient(180deg,#0b1220,#02060c);border:1px solid rgba(56,189,248,.35);border-radius:12px;color:#fff;\"><div style=\"font-size:11px;color:#67e8f9;\">Runtime Panel</div><div style=\"font-size:18px;font-weight:900;margin-top:4px;\">統合制御</div><div style=\"margin-top:8px;display:flex;gap:6px;font-size:10px;\"><span style=\"flex:1;padding:6px 4px;background:#111827;border-left:2px solid #22c55e;border-radius:6px;text-align:center;\">許可</span><span style=\"flex:1;padding:6px 4px;background:#111827;border-left:2px solid #f59e0b;border-radius:6px;text-align:center;\">保留</span><span style=\"flex:1;padding:6px 4px;background:#111827;border-left:2px solid #ef4444;border-radius:6px;text-align:center;\">停止</span></div><div style=\"margin-top:6px;font-size:11px;color:#94a3b8;\">開く →</div></a>"

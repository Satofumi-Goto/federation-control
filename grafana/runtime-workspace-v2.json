        "mode": "html",
        "content": "<a href=\"/d/go-integrated-surface/integrated-control-surface\" style=\"display:block;width:100%;height:100%;min-height:0;overflow:hidden;padding:10px 12px;text-decoration:none;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-radius:12px;box-sizing:border-box;color:var(--text-primary,#111827);box-shadow:0 1px 2px rgba(15,23,42,.04);\">\n    <div style=\"display:flex;align-items:center;justify-content:space-between;gap:8px;\"><div><div style=\"font-size:11px;font-weight:600;color:#0891b2;\">崩壊制御 Runtime</div><div style=\"font-size:18px;font-weight:700;margin-top:2px;color:var(--text-primary,#111827);\">統合制御</div></div><div style=\"font-size:10px;color:#d97706;font-weight:700;\">3段構造</div></div>\n    <div style=\"display:grid;grid-template-columns:116px 1fr;gap:10px;align-items:center;margin-top:6px;height:86px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-radius:10px;padding:6px;\"><div style=\"width:86px;height:86px;border-radius:50%;background:conic-gradient(from -90deg,#f59e0b 0% 32%,#38bdf8 32% 56%,#8b5cf6 56% 74%,#ef4444 74% 90%,#22c55e 90% 100%);position:relative;justify-self:center;\"><div style=\"position:absolute;top:13px;left:13px;right:13px;bottom:13px;border-radius:50%;background:var(--background-primary,#fff);display:flex;align-items:center;justify-content:center;text-align:center;font-size:10px;font-weight:700;line-height:1.2;color:var(--text-primary,#111827);\">直ぐに<br/>崩壊</div></div><div style=\"display:grid;grid-template-columns:repeat(2,1fr);gap:4px;font-size:10px;\"><div style=\"display:flex;align-items:center;gap:5px;min-width:0;color:var(--text-secondary,#64748b);\"><span style=\"width:7px;height:7px;border-radius:50%;background:#f59e0b;display:inline-block;flex:0 0 auto;\"></span><span style=\"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Queue 32%</span></div><div style=\"display:flex;align-items:center;gap:5px;min-width:0;color:var(--text-secondary,#64748b);\"><span style=\"width:7px;height:7px;border-radius:50%;background:#38bdf8;display:inline-block;flex:0 0 auto;\"></span><span style=\"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">ETA 24%</span></div><div style=\"display:flex;align-items:center;gap:5px;min-width:0;color:var(--text-secondary,#64748b);\"><span style=\"width:7px;height:7px;border-radius:50%;background:#8b5cf6;display:inline-block;flex:0 0 auto;\"></span><span style=\"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">ODD 18%</span></div><div style=\"display:flex;align-items:center;gap:5px;min-width:0;color:var(--text-secondary,#64748b);\"><span style=\"width:7px;height:7px;border-radius:50%;background:#ef4444;display:inline-block;flex:0 0 auto;\"></span><span style=\"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Constraint 16%</span></div><div style=\"display:flex;align-items:center;gap:5px;min-width:0;color:var(--text-secondary,#64748b);\"><span style=\"width:7px;height:7px;border-radius:50%;background:#22c55e;display:inline-block;flex:0 0 auto;\"></span><span style=\"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Dispatch 10%</span></div></div></div>\n    <div style=\"margin-top:6px;padding:7px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-radius:9px;\"><div style=\"display:grid;grid-template-columns:92px 1fr 30px;align-items:center;gap:6px;margin-bottom:4px;\"><div style=\"font-size:10px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Queue→ETA</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:86%;background:#f59e0b;border-radius:999px;\"></div></div><div style=\"font-size:10px;color:var(--text-secondary,#64748b);text-align:right;\">86</div></div><div style=\"display:grid;grid-template-columns:92px 1fr 30px;align-items:center;gap:6px;margin-bottom:4px;\"><div style=\"font-size:10px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">ETA→Dispatch</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:72%;background:#38bdf8;border-radius:999px;\"></div></div><div style=\"font-size:10px;color:var(--text-secondary,#64748b);text-align:right;\">72</div></div><div style=\"display:grid;grid-template-columns:92px 1fr 30px;align-items:center;gap:6px;margin-bottom:4px;\"><div style=\"font-size:10px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Constraint→ODD</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:64%;background:#ef4444;border-radius:999px;\"></div></div><div style=\"font-size:10px;color:var(--text-secondary,#64748b);text-align:right;\">64</div></div><div style=\"display:grid;grid-template-columns:92px 1fr 30px;align-items:center;gap:6px;margin-bottom:4px;\"><div style=\"font-size:10px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">ODD→Fleet</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:58%;background:#8b5cf6;border-radius:999px;\"></div></div><div style=\"font-size:10px;color:var(--text-secondary,#64748b);text-align:right;\">58</div></div></div>\n    <div style=\"margin-top:6px;display:grid;grid-template-columns:repeat(4,1fr);gap:6px;\"><div style=\"padding:6px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:8px;min-width:0;\"><div style=\"font-size:9px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">成立率</div><div style=\"font-size:15px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis
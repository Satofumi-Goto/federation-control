0%;background:#38bdf8;flex:0 0 auto;\"></span><span>ETA 24%</span></div><div style=\"display:flex;align-items:center;gap:5px;color:var(--text-secondary,#64748b);font-size:9px;\"><span style=\"width:7px;height:7px;border-radius:50%;background:#8b5cf6;flex:0 0 auto;\"></span><span>ODD 18%</span></div><div style=\"display:flex;align-items:center;gap:5px;color:var(--text-secondary,#64748b);font-size:9px;\"><span style=\"width:7px;height:7px;border-radius:50%;background:#ef4444;flex:0 0 auto;\"></span><span>Constraint 16%</span></div><div style=\"display:flex;align-items:center;gap:5px;color:var(--text-secondary,#64748b);font-size:9px;\"><span style=\"width:7px;height:7px;border-radius:50%;background:#22c55e;flex:0 0 auto;\"></span><span>Dispatch 10%</span></div></div></div>\n    <div style=\"margin-top:5px;padding:6px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-radius:8px;\"><div style=\"display:grid;grid-template-columns:88px 1fr 28px;align-items:center;gap:5px;margin-bottom:3px;\"><div style=\"font-size:9px;color:var(--text-secondary,#64748b);\">Queue→ETA</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:86%;background:#f59e0b;border-radius:999px;\"></div></div><div style=\"font-size:9px;text-align:right;color:var(--text-secondary,#64748b);\">86</div></div><div style=\"display:grid;grid-template-columns:88px 1fr 28px;align-items:center;gap:5px;margin-bottom:3px;\"><div style=\"font-size:9px;color:var(--text-secondary,#64748b);\">ETA→Dispatch</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:72%;background:#38bdf8;border-radius:999px;\"></div></div><div style=\"font-size:9px;text-align:right;color:var(--text-secondary,#64748b);\">72</div></div><div style=\"display:grid;grid-template-columns:88px 1fr 28px;align-items:center;gap:5px;margin-bottom:3px;\"><div style=\"font-size:9px;color:var(--text-secondary,#64748b);\">Constraint→ODD</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:64%;background:#ef4444;border-radius:999px;\"></div></div><div style=\"font-size:9px;text-align:right;color:var(--text-secondary,#64748b);\">64</div></div><div style=\"display:grid;grid-template-columns:88px 1fr 28px;align-items:center;gap:5px;margin-bottom:3px;\"><div style=\"font-size:9px;color:var(--text-secondary,#64748b);\">ODD→Fleet</div><div style=\"height:7px;background:#f1f5f9;border-radius:999px;overflow:hidden;\"><div style=\"height:7px;width:58%;background:#8b5cf6;border-radius:999px;\"></div></div><div style=\"font-size:9px;text-align:right;color:var(--text-secondary,#64748b);\">58</div></div></div>\n    <div style=\"margin-top:5px;display:grid;grid-template-columns:repeat(3,1fr);gap:5px;\"><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Throughput</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">74%</div></div><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Trips</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">35/日</div></div><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #f59e0b;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Queue</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">12分</div></div><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">Runtime</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">AUTHORIZED</div></div><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">PL</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">+18%</div></div><div style=\"padding:5px 4px;background:var(--background-primary,#fff);border:1px solid var(--border-weak,#e5e7eb);border-left:3px solid #22c55e;border-radius:7px;min-width:0;\"><div style=\"font-size:8px;color:var(--text-secondary,#64748b);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">IRR</div><div style=\"font-size:13px;font-weight:700;color:var(--text-primary,#111827);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">12.4%</div></div></div>\n  </a>",
